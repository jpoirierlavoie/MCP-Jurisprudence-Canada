{
  "name": "jurisprudence-canlii",
  "version": "0.1.0",
  "private": true,
  "description": "Serveur MCP « Jurisprudence canadienne (CanLII) » — Worker Cloudflare, lecture seule.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types --strict-vars=false",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply canlii --local",
    "db:migrate:remote": "wrangler d1 migrations apply canlii --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  }
}
