# Node / Worker
node_modules/
.wrangler/
# généré par `wrangler types`
worker-configuration.d.ts

# ── Secrets locaux — ne JAMAIS versionner ────────────────────────────────────
# Ce dépôt est PUBLIC. Un secret commis une fois reste dans l'historique, dans
# les forks et dans les caches d'indexation même après suppression : la seule
# parade utile est de ne jamais l'y mettre. Les motifs ci-dessous sont
# délibérément plus larges que les fichiers réellement employés.
#
#   .dev.vars              clef d'API CanLII + secret partagé de développement
#   canlii.token           clef d'API CanLII
#   cf.token               jeton d'API Cloudflare
#   mcp.token / mcp.url    secret partagé du point d'entrée MCP (l'URL le CONTIENT)
*.token
.dev.vars
.dev.vars.*
!.dev.vars.example
mcp.url
.env
.env.*
.secrets/
# Filet supplémentaire : formes usuelles de matériel cryptographique.
*.key
*.pem
*.p12
*.pfx
*.keystore
secrets.json
credentials.json

# Artefacts de réconciliation du répertoire (scripts/refresh-databases.mjs)
reconcile-*.sql
reconcile-report.md

# Configuration locale d'outils.
#
# ⚠ `.claude/settings.local.json` n'était exclu que par le fichier d'exclusion
#   GLOBAL de la machine (~/.config/git/ignore) — une règle non versionnée, donc
#   absente de tout autre clone. La règle est répétée ici pour que l'exclusion
#   voyage avec le dépôt plutôt qu'avec le poste de travail.
.claude/settings.local.json
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
